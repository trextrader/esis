# Line endings
* text=auto
*.sh text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.json text eol=lf
*.py text eol=lf

# Binaries — diff as binary, no LFS (files are stored as regular git objects)
*.png binary
*.jpg binary
*.jpeg binary
*.pdf binary
*.wav binary
*.apk binary
*.aab binary
