{
  "expo": {
    "name": "ESIS",
    "slug": "esis-mobile",
    "version": "3.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/esis_logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#060D18"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#060D18"
      },
      "package": "com.esis.survival",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "FOREGROUND_SERVICE",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT"
      ]
    },
    "ios": {
      "infoPlist": {
        "NSFaceIDUsageDescription": "ESIS uses Face ID to confirm your identity before sending an emergency Code Blue broadcast."
      }
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "ESIS needs your location to send a crisis ping to nearby community helpers."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "e0ddc0b3-1193-4692-bf16-8d1af4904f38"
      }
    }
  }
}
